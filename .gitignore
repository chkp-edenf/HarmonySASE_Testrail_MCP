# Ignore everything by default
/*

# Except these files and directories
!/.gitignore
!/src/
!/packages/
!/README.md
!/USER_GUIDE.md
!/CLAUDE.md
!/mcp_config_example.json
!/pyproject.toml
!/.env.example
!/install.sh
!/install.ps1
!/docs/
!/tests/

# Ensure hidden files in allowed directories are included if needed
!/src/**
!/packages/**
!/docs/**
!/tests/**

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
