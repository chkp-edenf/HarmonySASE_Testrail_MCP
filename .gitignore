# Ignore everything by default
/*

# Except these files and directories
!/.gitignore
!/src/
!/README.md
!/USER_GUIDE.md
!/CLAUDE.md
!/mcp_config_example.json
!/pyproject.toml
!/.env.example

# Ensure hidden files in allowed directories are included if needed
!/src/**

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
